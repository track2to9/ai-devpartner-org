---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AI 수준 체크 | AI DevPartner" description="10개 질문으로 나의 AI 활용 수준을 확인해보세요. 1분이면 충분합니다." currentPage="/ai-check">

  <div class="tf-page" id="tfPage">

    <!-- Slide: Intro -->
    <div class="tf-slide active" id="slideIntro">
      <div class="tf-slide-inner">
        <p class="tf-label">AI Level Check</p>
        <h1 class="tf-hero-title">나의 AI 활용 수준은?</h1>
        <p class="tf-hero-desc">
          10개 질문에 A 또는 B를 선택하세요.<br>
          현재 수준과 다음 단계 추천을 바로 알려드립니다.
        </p>
        <p class="tf-hero-meta">약 1분 소요 · 연락처 입력 없음</p>
        <button class="tf-start-btn" id="startBtn">
          시작하기
          <span class="tf-start-arrow">↓</span>
        </button>
        <p class="tf-key-hint">또는 Enter를 누르세요</p>
      </div>
    </div>

    <!-- Slide: Questions (generated by JS) -->
    <div class="tf-slide" id="slideQ" style="display:none;">
      <div class="tf-slide-inner">
        <div class="tf-progress">
          <div class="tf-progress-bar"><div class="tf-progress-fill" id="pFill"></div></div>
          <span class="tf-progress-text" id="pText">1/10</span>
        </div>
        <div class="tf-q-container" id="qContainer"></div>
      </div>
    </div>

    <!-- Slide: Result -->
    <div class="tf-slide" id="slideResult" style="display:none;">
      <div class="tf-slide-inner" id="resultInner"></div>
    </div>

  </div>

  <script is:inline>
  (function() {
    var questions = [
      { q: "AI 도구를 업무에 쓰고 있나요?", a: "ChatGPT나 Claude를 거의 매일 쓴다", b: "가끔 쓰거나 아직 안 써봤다" },
      { q: "AI에게 질문할 때", a: "원하는 결과가 나올 때까지 프롬프트를 다듬는다", b: "한 번 물어보고 결과가 별로면 포기한다" },
      { q: "반복 업무를 자동화한 경험이 있나요?", a: "엑셀 매크로, 자동화 도구 등을 써본 적 있다", b: "전부 수작업으로 처리한다" },
      { q: "\"API\"라는 단어를 들으면", a: "대충 뭔지 안다 (서비스를 연결하는 것)", b: "잘 모르겠다" },
      { q: "AI가 실수할 수 있다는 걸", a: "알고 있어서 결과를 항상 확인한다", b: "잘 생각 안 해봤다" },
      { q: "내 사업/업무 데이터가", a: "엑셀이나 시스템에 어느 정도 정리되어 있다", b: "여기저기 흩어져 있거나 종이/메모 위주다" },
      { q: "AI로 자동화하고 싶은 업무를", a: "구체적으로 1~2가지 떠올릴 수 있다", b: "\"뭔가 편해지면 좋겠다\" 정도만 느낀다" },
      { q: "새로운 IT 도구를 도입할 때", a: "직접 설치하고 써보는 편이다", b: "누군가 세팅해주면 쓴다" },
      { q: "AI가 내 업무에 미칠 영향이", a: "크다고 생각하고 준비해야 한다고 느낀다", b: "아직 먼 얘기 같다" },
      { q: "현재 업무에서 가장 아까운 것은", a: "시간 — 반복 업무에 시간을 뺏기고 있다", b: "비용 — IT에 투자할 여유가 아직 없다" }
    ];

    var results = [
      { min:0,max:3, icon:"🌱", level:"AI 입문자", score:25, color:"#06B6D4",
        desc:"AI에 관심은 있지만 아직 시작 전입니다. 괜찮습니다. 대부분의 사업자가 여기서 시작합니다.",
        tip:"먼저 ChatGPT나 Claude를 일주일만 써보세요. \"이메일 답장 초안 만들어줘\" 같은 간단한 것부터.",
        c1:{t:"AI 서비스 알아보기",h:"/services"}, c2:{t:"무료 진단 받기",h:"/diagnosis"} },
      { min:4,max:6, icon:"🌿", level:"AI 활용 초보", score:55, color:"#0D9488",
        desc:"AI를 쓰고는 있지만, 아직 업무에 깊이 연동하진 못한 단계입니다.",
        tip:"지금이 자동화를 시작하기 좋은 타이밍입니다. 반복 업무 1개만 자동화해도 효과를 체감할 수 있습니다.",
        c1:{t:"자동화 사례 보기",h:"/#cases"}, c2:{t:"무료 진단 받기",h:"/diagnosis"} },
      { min:7,max:8, icon:"🌳", level:"AI 적극 활용자", score:80, color:"#7B61FF",
        desc:"AI를 잘 쓰고 계시고, 자동화에 대한 이해도 있습니다. 이제 \"시스템\"으로 연결하면 효과가 배로 커집니다.",
        tip:"n8n이나 MCP 서버 같은 연동 도구를 검토해보세요. 전문가와 함께 설계하면 훨씬 빠릅니다.",
        c1:{t:"서비스 보기",h:"/services"}, c2:{t:"무료 진단 받기",h:"/diagnosis"} },
      { min:9,max:10, icon:"🚀", level:"AI 파워유저", score:95, color:"#00D4FF",
        desc:"이미 AI를 높은 수준으로 활용하고 계십니다. \"시스템화\"로 넘어가면 팀 전체가 같은 수준으로 활용할 수 있습니다.",
        tip:"AI 도입 컨설팅을 통해 조직 전체의 AI 활용 수준을 끌어올리는 것을 추천합니다.",
        c1:{t:"AI 컨설팅 보기",h:"/services/ai-automation"}, c2:{t:"무료 진단 받기",h:"/diagnosis"} }
    ];

    var cur = 0, locked = false;
    var answers = []; // 각 질문별 답변 기록

    function slideForward(from, to, cb) {
      from.classList.add('slide-out-left');
      setTimeout(function() {
        from.style.display = 'none';
        from.classList.remove('active','slide-out-left');
        to.style.display = '';
        to.classList.add('slide-in-right');
        requestAnimationFrame(function() {
          to.classList.add('active');
          setTimeout(function() { to.classList.remove('slide-in-right'); if(cb) cb(); }, 500);
        });
      }, 350);
    }

    function slideBack(from, to, cb) {
      from.classList.add('slide-out-right');
      setTimeout(function() {
        from.style.display = 'none';
        from.classList.remove('active','slide-out-right');
        to.style.display = '';
        to.classList.add('slide-in-left');
        requestAnimationFrame(function() {
          to.classList.add('active');
          setTimeout(function() { to.classList.remove('slide-in-left'); if(cb) cb(); }, 500);
        });
      }, 350);
    }

    document.getElementById('startBtn').addEventListener('click', function() {
      slideForward(document.getElementById('slideIntro'), document.getElementById('slideQ'));
      renderQ(0, 'forward');
    });

    document.addEventListener('keydown', function(e) {
      if (locked) return;
      if (e.key === 'Enter' && document.getElementById('slideIntro').classList.contains('active')) {
        document.getElementById('startBtn').click();
      }
      if (document.getElementById('slideQ').classList.contains('active')) {
        if (e.key === 'a' || e.key === 'A' || e.key === '1') selectAnswer('a');
        if (e.key === 'b' || e.key === 'B' || e.key === '2') selectAnswer('b');
      }
    });

    function renderQ(idx, dir) {
      cur = idx;
      var q = questions[idx];
      document.getElementById('pFill').style.width = ((idx+1)/questions.length*100) + '%';
      document.getElementById('pText').textContent = (idx+1) + ' / ' + questions.length;

      var c = document.getElementById('qContainer');
      var animClass = dir === 'back' ? 'q-enter-left' : 'q-enter-right';
      c.classList.remove('q-enter-right','q-enter-left');
      void c.offsetWidth;
      c.classList.add(animClass);

      var prevAnswer = answers[idx] || null;

      c.innerHTML =
        (idx > 0 ? '<button class="tf-back-btn" id="goBack">← 이전</button>' : '') +
        '<div class="tf-q-num">' + (idx+1) + ' →</div>' +
        '<h2 class="tf-q-text">' + q.q + '</h2>' +
        '<div class="tf-options">' +
          '<button class="tf-opt' + (prevAnswer==='a' ? ' selected' : '') + '" data-choice="a">' +
            '<span class="tf-opt-key">A</span>' +
            '<span class="tf-opt-text">' + q.a + '</span>' +
            '<span class="tf-opt-check">✓</span>' +
          '</button>' +
          '<button class="tf-opt' + (prevAnswer==='b' ? ' selected' : '') + '" data-choice="b">' +
            '<span class="tf-opt-key">B</span>' +
            '<span class="tf-opt-text">' + q.b + '</span>' +
            '<span class="tf-opt-check">✓</span>' +
          '</button>' +
        '</div>' +
        '<p class="tf-key-hint-q">키보드 A 또는 B로 선택</p>';

      c.querySelectorAll('.tf-opt').forEach(function(btn) {
        btn.addEventListener('click', function() { selectAnswer(this.getAttribute('data-choice')); });
      });

      var backBtn = document.getElementById('goBack');
      if (backBtn) {
        backBtn.addEventListener('click', function() {
          if (locked) return;
          renderQ(cur - 1, 'back');
        });
      }
    }

    function selectAnswer(choice) {
      if (locked) return;
      locked = true;

      // 이전 답변이 있으면 제거 후 새로 기록
      answers[cur] = choice;

      var selected = document.querySelector('.tf-opt[data-choice="'+choice+'"]');
      var other = document.querySelector('.tf-opt[data-choice="'+(choice==='a'?'b':'a')+'"]');
      selected.classList.add('selected');
      other.classList.remove('selected');
      other.classList.add('dimmed');

      setTimeout(function() {
        locked = false;
        if (cur < questions.length - 1) {
          renderQ(cur + 1, 'forward');
        } else {
          showResult();
        }
      }, 600);
    }

    function showResult() {
      // 답변 기록에서 A 개수 계산
      var aCount = answers.filter(function(a) { return a === 'a'; }).length;
      var r = results.find(function(x) { return aCount >= x.min && aCount <= x.max; });

      // localStorage에 결과 저장 → 진단 폼에서 활용
      try {
        localStorage.setItem('ai_check_result', JSON.stringify({
          level: r.level,
          score: r.score,
          aCount: aCount,
          answers: answers.slice(),
          timestamp: new Date().toISOString()
        }));
      } catch(e) {}

      slideForward(document.getElementById('slideQ'), document.getElementById('slideResult'));

      document.getElementById('resultInner').innerHTML =
        '<div class="tf-result">' +
          '<div class="tf-result-icon">' + r.icon + '</div>' +
          '<h2 class="tf-result-level" style="color:'+r.color+';">' + r.level + '</h2>' +
          '<div class="tf-result-bar-wrap">' +
            '<div class="tf-result-bar"><div class="tf-result-bar-fill" id="rBarFill" style="background:'+r.color+';"></div></div>' +
            '<span class="tf-result-score" style="color:'+r.color+';">' + r.score + '점</span>' +
          '</div>' +
          '<p class="tf-result-desc">' + r.desc + '</p>' +
          '<div class="tf-result-tip"><strong>다음 단계 추천</strong><p>' + r.tip + '</p></div>' +
          '<div class="tf-result-summary">' +
            '<div><span>A 선택</span><strong>'+aCount+'개</strong></div>' +
            '<div><span>B 선택</span><strong>'+(10-aCount)+'개</strong></div>' +
          '</div>' +
          '<div class="tf-result-ctas">' +
            '<a href="'+r.c1.h+'" class="btn-secondary">'+r.c1.t+'</a>' +
            '<a href="'+r.c2.h+'" class="btn-primary">'+r.c2.t+'</a>' +
          '</div>' +
          '<button class="tf-retry" onclick="location.reload()">다시 해보기</button>' +
        '</div>';

      setTimeout(function() {
        var fill = document.getElementById('rBarFill');
        if (fill) fill.style.width = r.score + '%';
      }, 300);
    }
  })();
  </script>

</BaseLayout>

<style is:global>
  /* Full-screen Typeform style — below header */
  .tf-page {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    background: #050505;
    z-index: 50;
  }

  .tf-slide {
    position: absolute;
    inset: 0;
    display: none;
    overflow-y: auto;
  }

  .tf-slide.active {
    display: flex;
  }

  .tf-slide-inner {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 32px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100dvh - var(--header-height));
  }

  /* Slide transitions — horizontal */
  .slide-out-left {
    animation: slideOutLeft 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .slide-in-right {
    animation: slideInRight 0.4s cubic-bezier(0.0, 0, 0.2, 1) forwards;
  }
  .slide-out-right {
    animation: slideOutRight 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .slide-in-left {
    animation: slideInLeft 0.4s cubic-bezier(0.0, 0, 0.2, 1) forwards;
  }

  @keyframes slideOutLeft {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(-80px); }
  }
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(80px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideOutRight {
    from { opacity: 1; transform: translateX(0); }
    to { opacity: 0; transform: translateX(80px); }
  }
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-80px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Question enter — horizontal */
  .q-enter-right {
    animation: qEnterRight 0.4s cubic-bezier(0.0, 0, 0.2, 1);
  }
  .q-enter-left {
    animation: qEnterLeft 0.4s cubic-bezier(0.0, 0, 0.2, 1);
  }

  @keyframes qEnterRight {
    from { opacity: 0; transform: translateX(60px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes qEnterLeft {
    from { opacity: 0; transform: translateX(-60px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Intro */
  .tf-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--primary);
    margin-bottom: 20px;
  }

  .tf-hero-title {
    font-family: 'Satoshi', 'Pretendard Variable', sans-serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .tf-hero-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .tf-hero-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 40px;
  }

  .tf-start-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 40px;
    border-radius: 12px;
    background: var(--gradient);
    color: #000;
    font-weight: 700;
    font-size: 1.1rem;
    font-family: inherit;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(0,212,255,0.25);
  }

  .tf-start-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,212,255,0.35);
  }

  .tf-start-arrow {
    animation: bounce 1.5s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  .tf-key-hint, .tf-key-hint-q {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 16px;
  }

  /* Progress */
  .tf-progress {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 48px;
  }

  .tf-progress-bar {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: var(--border);
    overflow: hidden;
  }

  .tf-progress-fill {
    height: 100%;
    background: var(--gradient);
    border-radius: 2px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tf-progress-text {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 600;
    min-width: 40px;
    text-align: right;
  }

  /* Question */
  .tf-q-num {
    font-size: 1rem;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 14px;
  }

  .tf-q-text {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 40px;
  }

  .tf-options {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .tf-opt {
    display: flex;
    align-items: center;
    gap: 18px;
    width: 100%;
    padding: 24px 28px;
    border-radius: 14px;
    background: rgba(255,255,255,0.06);
    border: 2px solid rgba(255,255,255,0.12);
    color: #F0F0F0;
    font-family: inherit;
    font-size: 1.05rem;
    text-align: left;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .tf-opt:hover {
    border-color: rgba(0,212,255,0.6);
    background: rgba(255,255,255,0.1);
    transform: translateX(8px);
  }

  .tf-opt-key {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: 10px;
    border: 2px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.9rem;
    color: #ccc;
    transition: all 0.25s;
    background: rgba(255,255,255,0.05);
  }

  .tf-opt-text {
    flex: 1;
    line-height: 1.6;
  }

  .tf-opt-check {
    opacity: 0;
    transform: scale(0);
    color: var(--primary);
    font-weight: 800;
    font-size: 1.3rem;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Selected state */
  .tf-opt.selected {
    border-color: #00D4FF;
    background: rgba(0,212,255,0.15);
    transform: translateX(8px);
  }

  .tf-opt.selected .tf-opt-key {
    background: var(--primary);
    border-color: var(--primary);
    color: #000;
  }

  .tf-opt.selected .tf-opt-check {
    opacity: 1;
    transform: scale(1);
  }

  .tf-opt.dimmed {
    opacity: 0.2;
    pointer-events: none;
    transform: translateX(0);
  }

  /* Result */
  .tf-result {
    text-align: center;
  }

  .tf-result-icon {
    font-size: 3.5rem;
    margin-bottom: 12px;
    animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.5); }
    to { opacity: 1; transform: scale(1); }
  }

  .tf-result-level {
    font-size: 2.2rem;
    font-weight: 900;
    margin-bottom: 24px;
  }

  .tf-result-bar-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 320px;
    margin: 0 auto 28px;
  }

  .tf-result-bar {
    flex: 1;
    height: 10px;
    border-radius: 5px;
    background: var(--border);
    overflow: hidden;
  }

  .tf-result-bar-fill {
    height: 100%;
    border-radius: 5px;
    width: 0;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tf-result-score {
    font-size: 1.2rem;
    font-weight: 800;
    min-width: 50px;
  }

  .tf-result-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 28px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .tf-result-tip {
    padding: 24px;
    border-radius: 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    margin: 0 auto 28px;
    text-align: left;
    max-width: 480px;
  }

  .tf-result-tip strong {
    font-size: 0.85rem;
    color: var(--primary);
    display: block;
    margin-bottom: 8px;
  }

