---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="상담 신청 완료 | 딸깍AI" description="상담 신청이 접수되었습니다." currentPage="/thank-you">

  <div class="thankyou-page">
    <div class="container" style="max-width:600px; text-align:center;">
      <div class="thankyou-icon fade-up">&#10003;</div>
      <h1 class="fade-up" style="font-size:1.8rem; font-weight:800; margin-bottom:16px;">상담 신청이 완료되었습니다!</h1>
      <p class="fade-up" style="color:var(--text-secondary); line-height:1.8; margin-bottom:32px;">
        영업일 기준 1일 이내에 연락드리겠습니다.<br>
        급한 문의는 우측 하단 채팅 또는 아래 연락처를 이용해 주세요.
      </p>
      <div class="thankyou-contact fade-up">
        <p>📧 contact@devpartner.org</p>
        <p>📞 050-6050-6188</p>
      </div>
      <a href="/" class="btn-secondary fade-up" style="display:inline-block; margin-top:32px;">홈으로 돌아가기</a>
    </div>
  </div>

</BaseLayout>

<style>
  .thankyou-page {
    padding-top: calc(var(--header-height) + 80px);
    padding-bottom: 120px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thankyou-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: #fff;
    font-weight: 800;
    margin: 0 auto 24px;
  }

  .thankyou-contact {
    padding: 24px;
    border-radius: 12px;
    background: var(--surface-alt);
    display: inline-block;
  }

  .thankyou-contact p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 4px 0;
  }
</style>
