---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="무료 AI 진단 | AI DevPartner" description="5단계 진단으로 업무 자동화 가능 영역과 예상 효과를 확인하세요." currentPage="/diagnosis">

  <div class="tf-page" id="tfPage">

    <!-- Slide 0: Intro -->
    <div class="tf-slide active" id="slide0">
      <div class="tf-slide-inner">
        <p class="tf-label">AI Diagnosis</p>
        <h1 class="tf-hero-title">무료 AI 업무 진단</h1>
        <p class="tf-hero-desc">
          5단계 질문에 답하면<br>
          자동화 가능 영역, 예상 절감 효과,<br>
          추천 솔루션을 바로 확인할 수 있습니다.
        </p>
        <p class="tf-hero-meta">약 2분 소요</p>
        <button class="tf-start-btn" onclick="goSlide(1)">
          진단 시작하기
          <span class="tf-start-arrow">↓</span>
        </button>
        <p class="tf-key-hint">또는 Enter를 누르세요</p>
      </div>
    </div>

    <!-- Slide 1: 업종 -->
    <div class="tf-slide" id="slide1" style="display:none;">
      <div class="tf-slide-inner">
        <div class="tf-progress"><div class="tf-progress-bar"><div class="tf-progress-fill" style="width:20%"></div></div><span>1/5</span></div>
        <div class="tf-q-num">1 →</div>
        <h2 class="tf-q-text">어떤 사업을 하고 계신가요?</h2>
        <div class="tf-grid-options" id="indGrid"></div>
        <div class="tf-insight" id="insight1"></div>
      </div>
    </div>

    <!-- Slide 2: 고통 포인트 -->
    <div class="tf-slide" id="slide2" style="display:none;">
      <div class="tf-slide-inner">
        <div class="tf-progress"><div class="tf-progress-bar"><div class="tf-progress-fill" style="width:40%"></div></div><span>2/5</span></div>
        <div class="tf-q-num">2 →</div>
        <h2 class="tf-q-text">가장 시간을 뺏기는 업무는?</h2>
        <p class="tf-q-sub">복수 선택 가능</p>
        <div class="tf-check-options" id="painGrid"></div>
        <div class="tf-insight" id="insight2"></div>
        <button class="tf-next-btn" id="pain-next" disabled onclick="goSlide(3)">다음 →</button>
      </div>
    </div>

    <!-- Slide 3: 현재 도구 -->
    <div class="tf-slide" id="slide3" style="display:none;">
      <div class="tf-slide-inner">
        <div class="tf-progress"><div class="tf-progress-bar"><div class="tf-progress-fill" style="width:60%"></div></div><span>3/5</span></div>
        <div class="tf-q-num">3 →</div>
        <h2 class="tf-q-text">현재 업무에 사용 중인 도구는?</h2>
        <p class="tf-q-sub">복수 선택 가능</p>
        <div class="tf-check-options" id="toolGrid"></div>
        <div class="tf-insight" id="insight3"></div>
        <button class="tf-next-btn" id="tool-next" disabled onclick="goSlide(4)">다음 →</button>
      </div>
    </div>

    <!-- Slide 4: 규모+긴급도 -->
    <div class="tf-slide" id="slide4" style="display:none;">
      <div class="tf-slide-inner">
        <div class="tf-progress"><div class="tf-progress-bar"><div class="tf-progress-fill" style="width:80%"></div></div><span>4/5</span></div>
        <div class="tf-q-num">4 →</div>
        <h2 class="tf-q-text">사업 규모와 도입 시기</h2>
        <div class="tf-sub-section">
          <h3 class="tf-sub-label">직원 수</h3>
          <div class="tf-row-options" id="sizeRow"></div>
        </div>
        <div class="tf-sub-section">
          <h3 class="tf-sub-label">도입 시기</h3>
          <div class="tf-col-options" id="urgencyCol"></div>
        </div>
        <div class="tf-insight" id="insight4"></div>
      </div>
    </div>

    <!-- Slide 5: 결과 + 폼 -->
    <div class="tf-slide" id="slide5" style="display:none;">
      <div class="tf-slide-inner" id="resultArea"></div>
    </div>

  </div>

  <script is:inline>
  (function() {
    var state = { industry:'', industryLabel:'', pains:[], tools:[], size:'', urgency:'' };

    var industries = [
      {v:'export',l:'수출/무역',tip:'수출/무역에서 가장 효과적: 이메일 관리, 바이어 팔로업, 서류 작성'},
      {v:'logistics',l:'물류/배송',tip:'물류에서는 배차 관리, 정산, 실시간 추적 자동화가 효과적'},
      {v:'retail',l:'유통/소매',tip:'유통/소매: 재고 관리, 주문 처리, 고객 응대 자동화'},
      {v:'service',l:'서비스업',tip:'서비스업: 예약 관리, 고객 문의 응대, 리뷰 관리 자동화'},
      {v:'manufacturing',l:'제조업',tip:'제조업: 발주서 처리, 품질 데이터 분석, 보고서 자동화'},
      {v:'it',l:'IT/스타트업',tip:'IT: CI/CD, 모니터링, 고객 온보딩 자동화'},
      {v:'realestate',l:'부동산',tip:'부동산: 매물 관리, 고객 매칭, 계약서 처리 자동화'},
      {v:'education',l:'교육/학원',tip:'교육: 학부모 응대, 출결 관리, 성적 분석 자동화'},
      {v:'other',l:'기타',tip:'어떤 업종이든 반복 업무가 있다면 자동화할 수 있습니다'}
    ];

    var pains = [
      {v:'email',l:'이메일 작성/응대',h:5},
      {v:'data',l:'데이터 입력/정리 (엑셀 등)',h:6},
      {v:'cs',l:'고객 문의 응대',h:5},
      {v:'report',l:'보고서/문서 작성',h:4},
      {v:'payroll',l:'급여/정산 처리',h:4},
      {v:'research',l:'정보 검색/리서치',h:3},
      {v:'sns',l:'SNS/마케팅 콘텐츠',h:3},
      {v:'other',l:'기타',h:3}
    ];

    var tools = [
      {v:'excel',l:'엑셀/구글 스프레드시트'},
      {v:'gmail',l:'Gmail/Outlook'},
      {v:'kakao',l:'카카오톡/문자'},
      {v:'notion',l:'Notion/노션'},
      {v:'crm',l:'CRM (세일즈포스 등)'},
      {v:'custom',l:'자체 시스템/ERP'},
      {v:'paper',l:'종이/수작업'}
    ];

    var sizes = ['1명','2~5명','6~20명','20명+'];
    var urgencies = [{v:'now',l:'바로 시작하고 싶다'},{v:'1month',l:'1개월 내 검토 중'},{v:'exploring',l:'아직 알아보는 단계'}];

    var currentSlide = 0;

    // Render slide 1
    var ig = document.getElementById('indGrid');
    industries.forEach(function(ind,i) {
      var b = document.createElement('button');
      b.className = 'tf-grid-opt';
      b.innerHTML = '<span class="tf-opt-key">' + String.fromCharCode(65+i) + '</span><span>' + ind.l + '</span><span class="tf-opt-check">✓</span>';
      b.addEventListener('click', function() {
        state.industry = ind.v;
        state.industryLabel = ind.l;
        ig.querySelectorAll('.tf-grid-opt').forEach(function(x){x.classList.remove('selected');});
        this.classList.add('selected');
        document.getElementById('insight1').innerHTML = '<p>'+ind.tip+'</p>';
        setTimeout(function(){ goSlide(2); }, 700);
      });
      ig.appendChild(b);
    });

    // Render slide 2
    var pg = document.getElementById('painGrid');
    pains.forEach(function(p,i) {
      var l = document.createElement('label');
      l.className = 'tf-check-opt';
      l.innerHTML = '<span class="tf-opt-key">' + String.fromCharCode(65+i) + '</span><input type="checkbox" value="'+p.v+'" data-hours="'+p.h+'"><span class="tf-check-label">'+p.l+'</span><span class="tf-opt-check">✓</span>';
      pg.appendChild(l);
    });
    pg.addEventListener('change', function() {
      state.pains = [];
      var totalH = 0;
      pg.querySelectorAll('input:checked').forEach(function(c) {
        state.pains.push(c.value);
        totalH += parseInt(c.getAttribute('data-hours'));
      });
      var btn = document.getElementById('pain-next');
      btn.disabled = state.pains.length === 0;
      if (totalH > 0) {
        var saving = Math.round(totalH*4*25000/10000);
        document.getElementById('insight2').innerHTML = '<p>선택하신 업무를 자동화하면<br><strong>예상 절감: 주 '+totalH+'시간+ (월 약 '+saving+'만원)</strong></p>';
      } else {
        document.getElementById('insight2').innerHTML = '';
      }
    });

    // Render slide 3
    var tg = document.getElementById('toolGrid');
    tools.forEach(function(t,i) {
      var l = document.createElement('label');
      l.className = 'tf-check-opt';
      l.innerHTML = '<span class="tf-opt-key">' + String.fromCharCode(65+i) + '</span><input type="checkbox" value="'+t.v+'"><span class="tf-check-label">'+t.l+'</span><span class="tf-opt-check">✓</span>';
      tg.appendChild(l);
    });
    tg.addEventListener('change', function() {
      state.tools = [];
      tg.querySelectorAll('input:checked').forEach(function(c){ state.tools.push(c.value); });
      document.getElementById('tool-next').disabled = state.tools.length === 0;
      var tips = [];
      if (state.tools.indexOf('excel')>=0 && state.tools.indexOf('gmail')>=0) tips.push('Gmail + 스프레드시트 조합은 n8n으로 자동화하면 가장 빠릅니다.');
      if (state.tools.indexOf('notion')>=0) tips.push('Notion은 API가 잘 되어 있어 연동이 수월합니다.');
      if (state.tools.indexOf('paper')>=0) tips.push('수작업이 많을수록 자동화 효과가 큽니다.');
      document.getElementById('insight3').innerHTML = tips.length ? '<p>'+tips[0]+'</p>' : '';
    });

    // Render slide 4
    var sr = document.getElementById('sizeRow');
    sizes.forEach(function(s) {
      var b = document.createElement('button');
      b.className = 'tf-row-opt';
      b.textContent = s;
      b.addEventListener('click', function() {
        state.size = s;
        sr.querySelectorAll('.tf-row-opt').forEach(function(x){x.classList.remove('selected');});
        this.classList.add('selected');
        checkStep4();
      });
      sr.appendChild(b);
    });
    var uc = document.getElementById('urgencyCol');
    urgencies.forEach(function(u,i) {
      var b = document.createElement('button');
      b.className = 'tf-col-opt';
      b.innerHTML = '<span class="tf-opt-key">'+String.fromCharCode(65+i)+'</span><span>'+u.l+'</span><span class="tf-opt-check">✓</span>';
      b.addEventListener('click', function() {
        state.urgency = u.v;
        uc.querySelectorAll('.tf-col-opt').forEach(function(x){x.classList.remove('selected');});
        this.classList.add('selected');
        checkStep4();
      });
      uc.appendChild(b);
    });

    function checkStep4() {
      if (!state.size || !state.urgency) return;
      var tip = state.urgency==='now' ? '바로 시작하신다면 추천: 구축 패키지 (200~400만원)' :
                state.urgency==='1month' ? '무료 진단으로 범위를 먼저 확인해보세요.' :
                '진단 결과를 참고자료로 활용해보세요.';
      document.getElementById('insight4').innerHTML = '<p>'+tip+'</p>';
      setTimeout(function(){ goSlide(5); }, 800);
    }

    // Slide transition
    window.goSlide = function(to) {
      var from = document.getElementById('slide' + currentSlide);
      var target = document.getElementById('slide' + to);
      from.classList.add('slide-out-up');
      setTimeout(function() {
        from.style.display = 'none';
        from.classList.remove('active','slide-out-up');
        target.style.display = '';
        target.classList.add('slide-in-up');
        requestAnimationFrame(function() {
          target.classList.add('active');
          setTimeout(function(){ target.classList.remove('slide-in-up'); }, 600);
        });
        currentSlide = to;
        if (to === 5) renderResult();
      }, 400);
    };

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && currentSlide === 0) goSlide(1);
    });

    function renderResult() {
      var totalH = 0;
      state.pains.forEach(function(p) { var o=pains.find(function(x){return x.v===p;}); if(o) totalH+=o.h; });
      var saving = Math.round(totalH*4*25000/10000);
      var sol = 'AI 업무 자동화 구축';
      if (state.pains.indexOf('cs')>=0) sol='AI 챗봇 + 업무 자동화';
      if (state.pains.indexOf('email')>=0 && state.pains.indexOf('data')>=0) sol='n8n 워크플로우 + AI 자동화';
      var fit = 60;
      if (state.pains.length>=3) fit+=15;
      if (state.urgency==='now') fit+=15;
      if (state.tools.indexOf('excel')>=0||state.tools.indexOf('gmail')>=0) fit+=10;
      fit = Math.min(fit,98);

      var painLabels = state.pains.map(function(p){var o=pains.find(function(x){return x.v===p;});return o?o.l:p;}).join(', ');
      var toolLabels = state.tools.map(function(t){var o=tools.find(function(x){return x.v===t;});return o?o.l:t;}).join(', ');

      document.getElementById('resultArea').innerHTML =
        '<div class="tf-diag-result">' +
          '<h2 class="tf-diag-title">AI 자동화 진단 결과</h2>' +
          '<div class="tf-diag-stats">' +
            '<div class="tf-diag-stat"><span class="tf-diag-num">주 '+totalH+'시간+</span><span class="tf-diag-label">예상 절감 시간</span></div>' +
            '<div class="tf-diag-stat"><span class="tf-diag-num">월 ~'+saving+'만원</span><span class="tf-diag-label">비용 절감 효과</span></div>' +
            '<div class="tf-diag-stat"><span class="tf-diag-num">'+fit+'%</span><span class="tf-diag-label">자동화 적합도</span></div>' +
          '</div>' +
          '<div class="tf-diag-detail">' +
            '<div class="tf-diag-row"><span>업종</span><span>'+state.industryLabel+'</span></div>' +
            '<div class="tf-diag-row"><span>자동화 대상</span><span>'+painLabels+'</span></div>' +
            '<div class="tf-diag-row"><span>현재 도구</span><span>'+toolLabels+'</span></div>' +
            '<div class="tf-diag-row"><span>추천 솔루션</span><span style="color:var(--primary);font-weight:700;">'+sol+'</span></div>' +
          '</div>' +
          '<div class="tf-diag-form-box">' +
            '<h3>상세 진단 리포트를 받아보세요</h3>' +
            '<p>전문가가 직접 분석한 맞춤 자동화 방안을 보내드립니다.</p>' +
            '<form id="diagForm" action="https://api.web3forms.com/submit" method="POST">' +
              '<input type="hidden" name="access_key" value="49321127-3e8c-47dd-a8e1-ecb942599407">' +
              '<input type="hidden" name="subject" value="[AI DevPartner] AI 진단 리포트 요청">' +
              '<input type="hidden" name="from_name" value="AI DevPartner 진단폼">' +
              '<input type="hidden" name="redirect" value="https://ai.devpartner.org/thank-you">' +
              '<input type="hidden" name="industry" value="'+state.industryLabel+'">' +
              '<input type="hidden" name="pains" value="'+painLabels+'">' +
              '<input type="hidden" name="tools" value="'+toolLabels+'">' +
              '<input type="hidden" name="size" value="'+state.size+'">' +
              '<input type="hidden" name="urgency" value="'+state.urgency+'">' +
              '<input type="hidden" name="saving" value="주 '+totalH+'시간, 월 ~'+saving+'만원">' +
              '<input type="hidden" name="fit_score" value="'+fit+'%">' +
              '<input type="hidden" name="solution" value="'+sol+'">' +
              '<input type="checkbox" name="botcheck" style="display:none;">' +
              '<div class="tf-form-row"><input type="text" name="name" placeholder="이름 / 회사명" required></div>' +
              '<div class="tf-form-row"><input type="text" name="contact" placeholder="연락처 (전화번호 또는 이메일)" required></div>' +
              '<button type="submit" class="tf-submit-btn" id="diagSubmit">맞춤 진단 리포트 받기</button>' +
              '<p class="tf-form-note">제출하신 정보는 상담 목적으로만 사용됩니다.</p>' +
            '</form>' +
          '</div>' +
        '</div>';

      document.getElementById('diagForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = document.getElementById('diagSubmit');
        btn.textContent = '전송 중...'; btn.disabled = true;
        fetch(this.action, {method:'POST',body:new FormData(this)})
          .then(function(r){return r.json();})
          .then(function(d){
            if(d.success) window.location.href='/thank-you';
            else { btn.textContent='맞춤 진단 리포트 받기'; btn.disabled=false; alert('전송 실패. contact@devpartner.org로 문의해주세요.'); }
          })
          .catch(function(){ btn.textContent='맞춤 진단 리포트 받기'; btn.disabled=false; alert('네트워크 오류.'); });
      });
    }
  })();
  </script>

</BaseLayout>

<style>
  .tf-page { position: fixed; inset: 0; overflow: hidden; background: var(--bg); z-index: 100; }
  .tf-slide { position: absolute; inset: 0; display: none; overflow-y: auto; }
  .tf-slide.active { display: flex; }
  .tf-slide-inner { width: 100%; max-width: 640px; margin: 0 auto; padding: 80px 24px; display: flex; flex-direction: column; justify-content: center; min-height: 100vh; }

  .slide-out-up { animation: slideOutUp 0.4s cubic-bezier(0.4,0,0.2,1) forwards; }
  .slide-in-up { animation: slideInUp 0.5s cubic-bezier(0.0,0,0.2,1) forwards; }
  @keyframes slideOutUp { from{opacity:1;transform:translateY(0)} to{opacity:0;transform:translateY(-60px)} }
  @keyframes slideInUp { from{opacity:0;transform:translateY(60px)} to{opacity:1;transform:translateY(0)} }

  .tf-label { font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; color:var(--primary); margin-bottom:20px; }
  .tf-hero-title { font-family:'Satoshi','Pretendard Variable',sans-serif; font-size:clamp(2rem,5vw,3.2rem); font-weight:900; line-height:1.2; letter-spacing:-0.03em; margin-bottom:16px; }
  .tf-hero-desc { font-size:1.1rem; color:var(--text-secondary); line-height:1.8; margin-bottom:8px; }
  .tf-hero-meta { font-size:0.85rem; color:var(--text-muted); margin-bottom:40px; }
  .tf-start-btn { display:inline-flex; align-items:center; gap:10px; padding:18px 40px; border-radius:12px; background:var(--gradient); color:#000; font-weight:700; font-size:1.1rem; font-family:inherit; border:none; cursor:pointer; transition:transform 0.2s,box-shadow 0.2s; box-shadow:0 4px 24px rgba(0,212,255,0.25); }
  .tf-start-btn:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(0,212,255,0.35); }
  .tf-start-arrow { animation: bounce 1.5s infinite; }
  @keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(4px)} }
  .tf-key-hint { font-size:0.8rem; color:var(--text-muted); margin-top:16px; }

  .tf-progress { display:flex; align-items:center; gap:12px; margin-bottom:48px; }
  .tf-progress-bar { flex:1; height:4px; border-radius:2px; background:var(--border); overflow:hidden; }
  .tf-progress-fill { height:100%; background:var(--gradient); border-radius:2px; transition:width 0.5s; }
  .tf-progress span { font-size:0.82rem; color:var(--text-muted); font-weight:600; }

  .tf-q-num { font-size:0.9rem; color:var(--primary); font-weight:600; margin-bottom:12px; }
  .tf-q-text { font-size:clamp(1.3rem,3vw,1.7rem); font-weight:700; line-height:1.5; margin-bottom:24px; }
  .tf-q-sub { font-size:0.85rem; color:var(--text-muted); margin-bottom:20px; }

  .tf-opt-key { width:32px; height:32px; min-width:32px; border-radius:8px; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.8rem; color:var(--text-secondary); transition:all 0.25s; flex-shrink:0; }
  .tf-opt-check { opacity:0; transform:scale(0); color:var(--primary); font-weight:800; font-size:1.1rem; transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1); margin-left:auto; flex-shrink:0; }

  /* Grid options (industry) */
  .tf-grid-options { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
