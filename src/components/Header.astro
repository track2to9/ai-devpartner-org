---
interface Props {
  currentPage?: string;
}
const { currentPage = '/' } = Astro.props;
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <div class="logo-icon">AI</div>
      <span>AI DevPartner</span>
    </a>
    {currentPage === '/' ? (
      <nav>
        <a href="#ai-services">AI 서비스</a>
        <a href="#about">OpenClaw</a>
        <a href="#pricing" data-tab="claude">Claude 도입</a>
        <a href="#reviews">고객 후기</a>
        <a href="#pricing">요금제</a>
        <a href="#faq">FAQ</a>
        <a href="#contact" class="nav-cta" data-chat>무료 상담</a>
      </nav>
    ) : (
      <nav>
        <a href="/">홈</a>
        <a href="/#ai-services">AI 서비스</a>
        <a href="/#pricing">요금제</a>
        <a href="#" class="nav-cta" data-chat>무료 상담</a>
      </nav>
    )}
    <button class="mobile-toggle" id="mobileToggle" aria-label="메뉴 열기">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

{currentPage === '/' ? (
  <div class="mobile-overlay" id="mobileMenu">
    <button class="mobile-close" id="mobileClose" aria-label="메뉴 닫기">&times;</button>
    <a href="#ai-services" class="mobile-link">AI 서비스</a>
    <a href="#about" class="mobile-link">OpenClaw</a>
    <a href="#pricing" class="mobile-link" data-tab="claude">Claude 도입</a>
    <a href="#reviews" class="mobile-link">고객 후기</a>
    <a href="#pricing" class="mobile-link">요금제</a>
    <a href="#faq" class="mobile-link">FAQ</a>
    <a href="#" class="btn-primary mobile-link" data-chat style="margin-top:16px;">무료 상담</a>
  </div>
) : (
  <div class="mobile-overlay" id="mobileMenu">
    <button class="mobile-close" id="mobileClose" aria-label="메뉴 닫기">&times;</button>
    <a href="/" class="mobile-link">홈</a>
    <a href="/#ai-services" class="mobile-link">AI 서비스</a>
    <a href="/#pricing" class="mobile-link">요금제</a>
    <a href="#" class="btn-primary mobile-link" data-chat style="margin-top:16px;">무료 상담</a>
  </div>
)}
