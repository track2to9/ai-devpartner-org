---
interface Props {
  currentPage?: string;
}
const { currentPage = '/' } = Astro.props;
---

<header>
  <div class="container">
    <a href="/" class="logo">
      <div class="logo-icon">AI</div>
      <span>AI DevPartner</span>
    </a>
    <nav>
      <a href="/services">서비스</a>
      <a href="/#cases">사례</a>
      <a href="/#pricing">요금</a>
      <a href="/#about">소개</a>
      <a href="/contact" class="nav-cta">무료 진단</a>
    </nav>
    <button class="mobile-toggle" id="mobileToggle" aria-label="메뉴 열기">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mobile-overlay" id="mobileMenu">
  <button class="mobile-close" id="mobileClose" aria-label="메뉴 닫기">&times;</button>
  <a href="/" class="mobile-link">홈</a>
  <a href="/services" class="mobile-link">서비스</a>
  <a href="/#cases" class="mobile-link">사례</a>
  <a href="/#pricing" class="mobile-link">요금</a>
  <a href="/#about" class="mobile-link">소개</a>
  <a href="/contact" class="btn-primary mobile-link" style="margin-top:16px;">무료 진단</a>
</div>
